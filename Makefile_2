# **************************************************************************** #
#                                   VARIABLES                                  #
# **************************************************************************** #

NAME        = push_swap

CC          = cc
CFLAGS      = -Wall -Wextra -Werror
RM          = rm -f

INCLUDES    = -I.

SRC_DIR     = src
OP_DIR      = operations

SRCS        = $(SRC_DIR)/main.c \
              $(SRC_DIR)/error.c \
              $(SRC_DIR)/node_manipulations.c \
              $(SRC_DIR)/utils.c \
              $(OP_DIR)/swap.c \
              $(OP_DIR)/push.c \
              $(OP_DIR)/rotate.c \
              $(OP_DIR)/reverse_rotate.c

OBJS        = $(SRCS:.c=.o)

# **************************************************************************** #
#                                    RULES                                     #
# **************************************************************************** #

all: $(NAME)

$(NAME): $(OBJS)
	$(CC) $(CFLAGS) $(OBJS) $(INCLUDES) -o $(NAME)

%.o: %.c push_swap.h
	$(CC) $(CFLAGS) $(INCLUDES) -c $< -o $@

clean:
	$(RM) $(OBJS)

fclean: clean
	$(RM) $(NAME)

re: fclean all

.PHONY: all clean fclean re
